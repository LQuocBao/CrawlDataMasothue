#=============================================================================
# APPLICATION
#=============================================================================
APP_NAME="MaSoThue Scraper"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

#=============================================================================
# DATABASE
#=============================================================================
# DEV: Use SQLite or local MySQL
# PRODUCTION: Use managed MySQL/PostgreSQL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=masothue_scraper
DB_USERNAME=root
DB_PASSWORD=

#=============================================================================
# REDIS (Required for production queue + cache)
#=============================================================================
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0

#=============================================================================
# CACHE & QUEUE
#=============================================================================
# DEV: Use 'database' or 'sync' for simplicity
# PRODUCTION: Use 'redis' for performance
CACHE_DRIVER=redis
QUEUE_CONNECTION=sync
# QUEUE_CONNECTION=redis       # <-- Uncomment for production

#=============================================================================
# SCRAPER CONFIGURATION
#=============================================================================
SCRAPER_BASE_URL=https://masothue.com

# DEV: Leave empty to connect directly (no proxy)
# PRODUCTION: Set your rotating proxy endpoint
SCRAPER_PROXY_ENDPOINT=
# SCRAPER_PROXY_ENDPOINT=http://user:pass@rotating-proxy.example.com:8080

# Alternative: comma-separated static proxy list
SCRAPER_PROXY_LIST=

# SSL verification (disable only for debugging proxy issues)
SCRAPER_VERIFY_SSL=true

# Max companies per scrape cycle
SCRAPER_MAX_PER_RUN=50

# Schedule interval (minutes)
SCRAPER_INTERVAL_MINUTES=2

#=============================================================================
# TELEGRAM BOT
#=============================================================================
# Create a bot via @BotFather on Telegram
# These are stored per-config in the DB, but you can set defaults here
TELEGRAM_DEFAULT_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

#=============================================================================
# LOGGING
#=============================================================================
LOG_CHANNEL=stack
LOG_LEVEL=debug
# LOG_LEVEL=warning             # <-- Uncomment for production

#=============================================================================
# SESSION / MISC
#=============================================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
