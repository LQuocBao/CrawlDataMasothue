#=============================================================================
# PRODUCTION Environment Configuration
# Copy to .env on production server and fill in real values.
#=============================================================================

APP_NAME="MaSoThue Scraper"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://api.your-domain.com

# Frontend URL for CORS
FRONTEND_URL=https://your-domain.com

#=============================================================================
# DATABASE (Managed MySQL or Docker MySQL)
#=============================================================================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=masothue_scraper
DB_USERNAME=scraper
DB_PASSWORD=STRONG_PASSWORD_HERE

#=============================================================================
# REDIS (Required for queue + cache + dedup)
#=============================================================================
REDIS_HOST=redis
REDIS_PASSWORD=STRONG_REDIS_PASSWORD_HERE
REDIS_PORT=6379
REDIS_DB=0

#=============================================================================
# CACHE & QUEUE - MUST use Redis in production
#=============================================================================
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

#=============================================================================
# SCRAPER - Production Proxy Configuration
#=============================================================================
SCRAPER_BASE_URL=https://masothue.com

# Rotating proxy service (e.g., ScraperAPI, BrightData, Oxylabs)
# Format: http://username:password@proxy-endpoint:port
SCRAPER_PROXY_ENDPOINT=http://user:pass@gate.smartproxy.com:7000

SCRAPER_VERIFY_SSL=true
SCRAPER_MAX_PER_RUN=50
SCRAPER_INTERVAL_MINUTES=2

#=============================================================================
# TELEGRAM
#=============================================================================
TELEGRAM_DEFAULT_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

#=============================================================================
# LOGGING - Production uses minimal logging
#=============================================================================
LOG_CHANNEL=stack
LOG_LEVEL=warning
LOG_DEPRECATIONS_CHANNEL=null

#=============================================================================
# SESSION / MISC
#=============================================================================
SESSION_LIFETIME=120
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
