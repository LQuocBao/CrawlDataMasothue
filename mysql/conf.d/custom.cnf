[mysqld]
# Performance tuning for the scraper workload
# Mostly write-heavy (INSERTs) + indexed lookups

# Character set
character-set-server=utf8mb4
collation-server=utf8mb4_unicode_ci

# InnoDB settings
innodb_buffer_pool_size=256M
innodb_log_file_size=64M
innodb_flush_log_at_trx_commit=2
innodb_flush_method=O_DIRECT

# Connection settings
max_connections=150
wait_timeout=600
interactive_timeout=600

# Query cache (disabled in MySQL 8.0+ but kept for clarity)
# query_cache_type=0

# Slow query log
slow_query_log=1
long_query_time=2
slow_query_log_file=/var/log/mysql/slow-queries.log
